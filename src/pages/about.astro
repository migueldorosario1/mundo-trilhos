---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="pt-br">
	<head>
		<BaseHead title={`Quem Somos | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
		<style>
			main {
				max-width: 800px;
				margin: 0 auto;
				padding: 2em;
			}
			.about-container {
				background: white;
				padding: 3em;
				border-radius: 12px;
				box-shadow: 0 4px 20px rgba(0,0,0,0.05);
			}
			h1 { margin-bottom: 1em; }
			p { font-size: 1.1em; line-height: 1.8; color: #444; margin-bottom: 1.5em; }
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div class="about-container">
				<h1>Quem Somos</h1>
				<p>
					Este site foi idealizado e é curado pelo jornalista <strong>Miguel do Rosário</strong>, editor-chefe e fundador do portal <em>O Cafezinho</em>.
				</p>
				<p>
					Sediado em Niterói, Rio de Janeiro, Miguel também é o criador da rede de sites irmãos que inclui o Global South News, Mundo Trilhos, Discover Brazil e Rail Post, operando com uma visão multipolar e focada no desenvolvimento tecnológico e social global.
				</p>
			</div>
		</main>
		<Footer />
	</body>
</html>
