---
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import HeaderLink from './HeaderLink.astro';
import logoImg from '../assets/logo.png';
import { Image } from 'astro:assets';
---

<header class="premium-header">
	<nav class="navbar">
		<div class="brand">
			<a href="/" class="logo-link">
				<Image src={logoImg} alt={SITE_TITLE} width={150} height={150} class="logo-img" />
			</a>
			<div class="slogan">
				<span class="slogan-main" style="color: #2f3640;">Mundo Trilhos</span>
				<span class="slogan-sub" style="color: #e15f41;">Miguel do Rosário</span>
			</div>
		</div>
		<div class="nav-links">
			<HeaderLink href="/">Início</HeaderLink>
			
			
            <div class="nav-item dropdown">
                <button class="dropbtn">Tipos de Trem <span>▼</span></button>
                <div class="dropdown-content">
                    <a href="/tags/alta-velocidade">Alta Velocidade</a>
                    <a href="/tags/carga">Carga</a>
                    <a href="/tags/metros">Metrôs e VLTs</a>
                    <a href="/tags/turismo">Turismo</a>
                </div>
            </div>
            <div class="nav-item dropdown">
                <button class="dropbtn">Continentes <span>▼</span></button>
                <div class="dropdown-content">
                    <a href="/tags/america-sul">América do Sul</a>
                    <a href="/tags/europa">Europa</a>
                    <a href="/tags/asia">Ásia</a>
                    <a href="/tags/america-norte">América do Norte</a>
                </div>
            </div>

		</div>
	</nav>
</header>

<style>
	@import url('https://fonts.googleapis.com/css2?family=Montserrat:wght@800&family=Lora:ital,wght@1,500&family=Outfit:wght@500;600&display=swap');

	.premium-header {
		position: sticky;
		top: 0;
		z-index: 1000;
		background: rgba(255, 255, 255, 0.95);
		backdrop-filter: blur(16px);
		border-bottom: 1px solid rgba(0, 0, 0, 0.05);
		padding: 0.5rem 2rem;
		box-shadow: 0 4px 30px rgba(0, 0, 0, 0.03);
	}
	
	.navbar {
		display: flex;
		align-items: center;
		justify-content: space-between;
		max-width: 1200px;
		margin: 0 auto;
		padding: 0.5rem 0;
	}

	.brand {
		display: flex;
		align-items: center;
		gap: 1.5rem;
	}

	.logo-link { display: flex; align-items: center; width: 140px; height: 100px; margin-right: 20px; }

	.logo-img { height: 100px; width: auto; object-fit: contain; mix-blend-mode: multiply; }

	.slogan {
		display: flex;
		flex-direction: column;
		border-left: 3px solid #eee;
		padding-left: 1.5rem;
		gap: 0.1rem;
	}

	.slogan-main {
		font-family: 'Montserrat', sans-serif;
		font-size: 1.3rem;
		font-weight: 800;
		color: #111;
		letter-spacing: -0.5px;
		text-transform: uppercase;
	}

	.slogan-sub {
		font-family: 'Lora', serif;
		font-size: 1.05rem;
		font-style: italic;
		color: #d32f2f;
		font-weight: 500;
	}

	.badge {
		font-size: 0.6rem;
		background: #ff4757;
		color: white;
		padding: 2px 6px;
		border-radius: 10px;
		vertical-align: super;
		margin-left: 4px;
	}

	.nav-links {
		display: flex;
		align-items: center;
		gap: 2rem;
	}

	.nav-links :global(a) {
		font-family: 'Outfit', sans-serif;
		text-decoration: none;
		color: #333;
		font-weight: 600;
		font-size: 1.1rem;
		transition: color 0.2s;
		padding: 0.5rem 0;
		border-bottom: 2px solid transparent;
	}
	
	.nav-links :global(a:hover) {
		color: #0052D4;
	}
	
	.nav-links :global(a.active) {
		color: #0052D4;
		border-bottom: 2px solid #0052D4;
	}

	/* Dropdown Core */
	.nav-item {
		position: relative;
	}

	.dropbtn {
		font-family: 'Outfit', sans-serif;
		background: none;
		border: none;
		font-size: 1.1rem;
		font-weight: 600;
		color: #333;
		cursor: pointer;
		display: flex;
		align-items: center;
		gap: 0.3rem;
		padding: 0.5rem 0;
		transition: color 0.2s;
	}

	.dropbtn:hover {
		color: #0052D4;
	}

	.dropdown-content {
		visibility: hidden;
		opacity: 0;
		position: absolute;
		top: 120%;
		left: 50%;
		transform: translateX(-50%) translateY(10px);
		background: white;
		min-width: 240px;
		border-radius: 12px;
		box-shadow: 0 10px 40px rgba(0,0,0,0.1);
		padding: 0.5rem;
		transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
	}

	.dropdown:hover .dropdown-content {
		visibility: visible;
		opacity: 1;
		transform: translateX(-50%) translateY(0);
	}

	/* Submenu Core */
	.dropdown-submenu {
		position: relative;
		padding: 0.2rem;
	}

	.submenu-title {
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding: 0.8rem 1rem;
		color: #444;
		font-weight: 500;
		cursor: pointer;
		border-radius: 8px;
		transition: background 0.2s;
	}

	.submenu-title span {
		font-size: 0.7em;
		color: #aaa;
	}

	.dropdown-submenu:hover .submenu-title {
		background: #f4f7fb;
		color: #0052D4;
	}

	.submenu-content {
		visibility: hidden;
		opacity: 0;
		position: absolute;
		top: 0;
		left: 100%;
		margin-left: 0.5rem;
		background: white;
		min-width: 200px;
		border-radius: 12px;
		box-shadow: 0 10px 40px rgba(0,0,0,0.1);
		padding: 0.5rem;
		transform: translateX(10px);
		transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
	}

	.dropdown-submenu:hover .submenu-content {
		visibility: visible;
		opacity: 1;
		transform: translateX(0);
	}

	.submenu-content a {
		display: block;
		padding: 0.7rem 1rem;
		color: #555;
		text-decoration: none;
		border-radius: 6px;
		font-size: 0.95rem;
		transition: all 0.2s;
	}

	.submenu-content a:hover {
		background: #f4f7fb;
		color: #0052D4;
		padding-left: 1.2rem;
	}

	/* Mobile Responsiveness */
	@media (max-width: 768px) {
		.premium-header {
			padding: 0.5rem 1rem;
		}
		.navbar {
			flex-direction: column;
			gap: 1rem;
		}
		.nav-links {
			flex-wrap: wrap;
			justify-content: center;
			gap: 1rem;
		}
		.dropdown-content {
			position: static;
			transform: none;
			box-shadow: none;
			border: 1px solid #eee;
			display: none;
			width: 100%;
			margin-top: 10px;
		}
		.dropdown:hover .dropdown-content {
			display: block;
		}
		.dropdown-submenu .submenu-content {
			position: static;
			transform: none;
			box-shadow: none;
			border: none;
			margin-left: 1rem;
			border-left: 2px solid #eee;
			border-radius: 0;
		}
	}
</style>
